PORT=5000
# Use MONGO_URI (preferred) or MONGODB_URI for Atlas.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/workpulse
JWT_SECRET=change_this_to_a_long_random_string
CLIENT_ORIGIN=http://localhost:5173

# Bootstrap admin (optional): created/updated on server start. This email cannot be used on /register.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe_To_Something_Strong_123!
# Optional: do not re-apply ADMIN_PASSWORD on every server restart
# ADMIN_SKIP_PASSWORD_SYNC=1

# MONGODB_USE_PUBLIC_DNS=1
